# ══════════════════════════════════════════════════════════════════════════════
# De Paseo en Fincas — Variables de entorno
# Copia este archivo como .env y completa los valores
# ══════════════════════════════════════════════════════════════════════════════

# ─── Base de datos (Supabase o Neon) ─────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres?pgbouncer=true"
DATABASE_URL_UNPOOLED="postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres"

# ─── NextAuth.js ─────────────────────────────────────────────────────────────
NEXTAUTH_SECRET="genera-con-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# ─── Google OAuth (para login y Calendar) ────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Google Calendar (encriptación AES-256) ───────────────────────────────────
# Genera: openssl rand -hex 32
GOOGLE_CALENDAR_ENCRYPTION_KEY=""

# ─── LLM — Groq (proveedor primario) ─────────────────────────────────────────
GROQ_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"
GROQ_TIMEOUT_MS="8000"

# ─── LLM — DeepSeek (fallback) ───────────────────────────────────────────────
DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com/v1"
DEEPSEEK_MODEL="deepseek-chat"

# ─── LLM — Parámetros ────────────────────────────────────────────────────────
LLM_MAX_TOKENS="1024"
LLM_TEMPERATURE="0.7"

# ─── OpenAI (embeddings RAG) ─────────────────────────────────────────────────
OPENAI_API_KEY=""
EMBEDDING_MODEL="text-embedding-3-small"
EMBEDDING_DIMENSIONS="1536"

# ─── WhatsApp Business API (Meta) ────────────────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_VERIFY_TOKEN="depaseo_verify_2025"
WHATSAPP_APP_SECRET=""
WHATSAPP_API_URL="https://graph.facebook.com/v19.0"

# ─── Instagram Graph API (Meta) ──────────────────────────────────────────────
INSTAGRAM_PAGE_ACCESS_TOKEN=""
INSTAGRAM_APP_SECRET=""
INSTAGRAM_API_URL="https://graph.facebook.com/v19.0"

# ─── Wompi (pagos Colombia) ───────────────────────────────────────────────────
WOMPI_PUBLIC_KEY=""
WOMPI_PRIVATE_KEY=""
WOMPI_INTEGRITY_SECRET=""
WOMPI_EVENTS_SECRET=""

# ─── Cloudinary (imágenes) ────────────────────────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_UPLOAD_PRESET="depaseo_fincas"

# ─── Mapbox (mapas) ──────────────────────────────────────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=""

# ─── Resend (emails transaccionales) ─────────────────────────────────────────
RESEND_API_KEY=""
FROM_EMAIL="noreply@depaseoenfincas.co"

# ─── Redis (BullMQ) ──────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Gateway ─────────────────────────────────────────────────────────────────
GATEWAY_PORT="3001"
GATEWAY_URL="http://localhost:3001"
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3002,http://localhost:3003"

# ─── Bot worker ──────────────────────────────────────────────────────────────
MESSAGE_QUEUE_CONCURRENCY="5"
MESSAGE_QUEUE_MAX_RETRIES="3"
MESSAGE_QUEUE_RATE_PER_SECOND="10"
BOT_MAX_CONTEXT_MESSAGES="20"
BOT_MAX_TOOL_ITERATIONS="5"
SESSION_TTL_HOURS="24"

# ─── Scheduler / recordatorios ───────────────────────────────────────────────
REMINDER_PRE_TRIP_HOURS="48"
REMINDER_LOGISTICS_HOURS="24"
REMINDER_CHECKIN_HOURS="0"
REMINDER_POST_STAY_HOURS="6"
REMINDER_REENGAGEMENT_30="30"
REMINDER_REENGAGEMENT_60="60"
REMINDER_REENGAGEMENT_90="90"
NOTIFICATION_MAX_RETRIES="3"

# ─── App URLs ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:3000"
NEXT_PUBLIC_GATEWAY_WS_URL="ws://localhost:3001/ws"
NEXT_PUBLIC_GATEWAY_URL="http://localhost:3001"

# ─── WhatsApp número para clientes ───────────────────────────────────────────
NEXT_PUBLIC_WHATSAPP_NUMBER="573001234567"

# ─── Brand colors ────────────────────────────────────────────────────────────
NEXT_PUBLIC_BRAND_COLOR_PRIMARY="E8832A"
NEXT_PUBLIC_BRAND_COLOR_DARK="1A1D2E"

# ─── Wompi widget ────────────────────────────────────────────────────────────
NEXT_PUBLIC_WOMPI_PUBLIC_KEY=""
